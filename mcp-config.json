{
  "mcpServers": {
    "db-query": {
      "command": "uv",
      "args": [
        "--directory",
        "./mcp-servers/db-query-mcp-server",
        "run",
        "main.py"
      ],
      "env": {
        "MCP_LOG_LEVEL": "ERROR"
      }
    },
    "visualization": {
      "command": "uvx",
      "args": [
        "--from", "./mcp-servers/plotting-mcp",
        "plotting-mcp", "--transport=stdio"
      ]
    },
    "sandbox": {
      "url": "http://mcp-sandbox:8080/sse"
    }
  }
}
