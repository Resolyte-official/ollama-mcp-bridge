{
  "mcpServers": {
    "db-query": {
      "command": "uv",
      "args": [
        "--directory",
        "./mcp-servers/db-query-mcp-server",
        "run",
        "main.py"
      ],
      "env": {
        "MCP_LOG_LEVEL": "ERROR"
      }
    },
    "remote_sse": {
      "url": "http://mcp-sandbox:8080/sse"
    }
  }
}
